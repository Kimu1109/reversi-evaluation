<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:reversi_evaluation.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
        x:Class="reversi_evaluation.Views.EvaluationHistoryWindow"
        x:DataType="vm:ReversiViewModel"
        Title="評価履歴"
        Width="400" Height="600"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Text="棋譜とEdax推奨手" Margin="10" FontSize="18" FontWeight="Bold"/>
        
        <ListBox Grid.Row="1" ItemsSource="{Binding PutHistories}" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="50,100,100,*">
                        <TextBlock Grid.Column="0" Text="{Binding TurnCount, StringFormat='\{0\}手'}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Turn, Converter={StaticResource CellStateConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="推奨: " Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding RecommendedMove, TargetNullValue='-'}" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="黒:" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding WinRateBlack, StringFormat='\{0\}%'}" Margin="2,0,5,0"/>
                            <TextBlock Text="白:" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding WinRateWhite, StringFormat='\{0\}%'}" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
