<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:reversi_evaluation.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="600"
        x:Class="reversi_evaluation.Views.EvaluationHistoryWindow"
        x:DataType="vm:EvaluationHistoryWindowViewModel"
        Title="評価履歴"
        Width="850" Height="600"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Text="棋譜とEdax推奨手" Margin="15,15,15,5" FontSize="18" FontWeight="Bold"/>
        
        <Grid Grid.Row="1" ColumnDefinitions="*,*">
            <!-- 画面左：履歴リスト -->
            <ListBox Grid.Column="0" ItemsSource="{Binding PutHistories}" SelectedItem="{Binding SelectedHistory}" Margin="10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="50,60,80,*">
                            <TextBlock Grid.Column="0" Text="{Binding TurnCount, StringFormat='\{0\}手'}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Turn, Converter={StaticResource CellStateConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="推奨: " Foreground="Gray" FontSize="12"/>
                                <TextBlock Text="{Binding RecommendedMove, TargetNullValue='-'}" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="黒:" FontSize="12" Foreground="Gray"/>
                                <TextBlock Text="{Binding WinRateBlack, StringFormat='\{0\}%'}" Margin="2,0,5,0"/>
                                <TextBlock Text="白:" FontSize="12" Foreground="Gray"/>
                                <TextBlock Text="{Binding WinRateWhite, StringFormat='\{0\}%'}" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 画面右：その時の盤面 -->
            <Grid Grid.Column="1" Margin="10">
                <Border ClipToBounds="True">
                    <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                        <ItemsControl ItemsSource="{Binding HistoryCells}" Width="400" Height="400">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="8" Columns="8" Background="DarkGreen"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Panel>
                                        <!-- セルの境界線 -->
                                        <Border BorderBrush="Black" BorderThickness="1"/>
                                        
                                        <!-- 通常の石 (黒・白) -->
                                        <Ellipse Margin="10"
                                                 Fill="{Binding PieceBrush}" 
                                                 IsVisible="{Binding IsOccupied}"
                                                 Stretch="Uniform"
                                                 StrokeThickness="2"
                                                 Stroke="Black"/>

                                        <!-- 推奨手表示 (石が置かれておらず、かつ推奨手の場合のみ表示) -->
                                        <Grid IsVisible="{Binding IsRecommended}">
                                            <!-- 黄色い半透明の枠線付きのマーク -->
                                            <Ellipse Margin="10"
                                                     Fill="#40FFD700" 
                                                     Stroke="Gold"
                                                     StrokeDashArray="4,2"
                                                     StrokeThickness="3"
                                                     Stretch="Uniform"/>
                                            <TextBlock Text="★" 
                                                       Foreground="Gold" 
                                                       FontWeight="Bold" 
                                                       FontSize="14" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Viewbox>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
